                  "pm.test('Status is 201 Created', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has event_id', () => {",
                  "    pm.expect(res.event_id).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('Status is queued', () => {",
                  "    pm.expect(res.status).to.eql('queued');",
                  "});",
                  "",
                  "pm.test('Has correlation_id', () => {",
                  "    pm.expect(res.correlation_id).to.be.a('string');",
                  "});",
                  "",
                  "if (res.correlation_id) {",
                  "    pm.collectionVariables.set('correlationId1', res.correlation_id);",
                  "    console.log('correlation_id (email):', res.correlation_id);",
                  "}"
