                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{eventId4}}\",\n  \"event_type\": \"appointment_confirmed\",\n  \"clinic_id\": \"{{clinicId}}\",\n  \"patient_id\": \"P-DEMO-04\",\n  \"channels\": [\"email\", \"sms\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
