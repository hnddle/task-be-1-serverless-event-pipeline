                  "if (res.notifications && res.notifications.length > 0) {",
                  "    const email = res.notifications.find(n => n.channel === 'email');",
                  "    const sms = res.notifications.find(n => n.channel === 'sms');",
                  "",
                  "    if (email) {",
                  "        pm.test('Email provider changed (not sendgrid)', () => {",
                  "            console.log('Email provider:', email.provider);",
                  "            pm.expect(email.provider).to.not.eql('sendgrid');",
                  "        });",
                  "    }",
                  "",
                  "    if (sms) {",
                  "        pm.test('SMS provider changed (not twilio)', () => {",
                  "            console.log('SMS provider:', sms.provider);",
                  "            pm.expect(sms.provider).to.not.eql('twilio');",
                  "        });",
                  "    }",
                  "}",
                  "",
                  "console.log('=== Provider Switch Verified ===');",
                  "console.log('Before: sendgrid / twilio');",
                  "console.log('After: check notifications[].provider in response body');"
                ],
                "type": "text/javascript"
              }
            }
