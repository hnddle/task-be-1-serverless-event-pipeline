                  "});",
                  "",
                  "if (res.correlation_id) {",
                  "    pm.collectionVariables.set('correlationId4', res.correlation_id);",
                  "    console.log('correlation_id (provider switch):', res.correlation_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const uuid = require('uuid');",
                  "const eventId = uuid.v4();",
                  "pm.collectionVariables.set('eventId4', eventId);",
